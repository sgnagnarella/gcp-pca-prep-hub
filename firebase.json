      "scratch/**",
      "package.json",
      "package-lock.json"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "GCP PCA Prep Hub",
        "supportEmail": "sgnagnarella@gmail.com"
      }
    }
  }
}
